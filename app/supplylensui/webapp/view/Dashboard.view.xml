<mvc:View
    controllerName="sravan.bristlecone.supplylensui.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page showHeader="false" class="slDashboardPage">

        <VBox class="slDashboardShell">

            <HBox class="slTopNav" alignItems="Center">

                <!-- Logo -->
                <VBox class="slBrandBlock">

                    <HBox alignItems="Center">
                        <Text text="Supply" class="slBrandDark"/>
                        <Text text="Lens" class="slBrandTeal"/>
                        <Text text="by Bristlecone" class="slBrandBy"/>
                    </HBox>

                    <Text
                        text="Fabless OEM Manufacturing Visibility . Ariba SCC + SAP BTP . Direct feeds only"
                        class="slBrandSub"/>

                </VBox>

                <!-- Navigation Tabs -->

                <HBox class="slTabContainer">

                    <VBox id="tabChipset" class="slTabItem">
                        <HBox alignItems="Center">
                            <Text text="#" class="slTabIcon"/>
                            <VBox>
                                <Link text="Chipset Risk" press=".onNavChipset" class="slTabTitle"/>
                                <Text text="Heatmap &amp; drill" class="slTabSub"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox id="tabBom" class="slTabItem">
                        <HBox alignItems="Center">
                            <Text text="" class="slTabIcon"/>
                            <VBox>
                                <Link text="BOM Management" press=".onNavBom" class="slTabTitle"/>
                                <Text text="Upload / S4 pull" class="slTabSub"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox id="tabComponent" class="slTabItem">
                        <HBox alignItems="Center">
                            <Text text="@" class="slTabIcon"/>
                            <VBox>
                                <Link text="Component Risk" press=".onNavComponent" class="slTabTitle"/>
                                <Text text="Per material view" class="slTabSub"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox id="tabAi" class="slTabItem">
                        <HBox alignItems="Center">
                            <Text text="*" class="slTabIcon"/>
                            <VBox>
                                <Link text="AI Recommendations" press=".onNavAi" class="slTabTitle"/>
                                <Text text="Powered by Claude" class="slTabSub"/>
                            </VBox>
                        </HBox>
                    </VBox>

                </HBox>

                <ToolbarSpacer/>

                <!-- Right -->

                <HBox class="slStatusArea" alignItems="Center">

                    <Text
                        text="2 feeds stale"
                        class="slFeedBadge"/>

                    <Button
                        text="● Live . Sync"
                        press=".onOpenSyncCenter"
                        class="slSyncBtn"/>

                </HBox>

            </HBox>

            <App id="dashboardApp" class="slInnerApp"/>

            <VBox
                    visible="{dashboard>/syncPanelVisible}"
                    class="slSyncOverlay">

                    <VBox class="slSyncPanel">

                        <HBox class="slSyncHeader" alignItems="Center">
                            <VBox>
                                <Text text="Data Sync Center" class="slSyncTitle"/>
                                <Text text="SAP S/4HANA + Ariba SCC . Real-time and scheduled feeds" class="slSyncSub"/>
                            </VBox>

                            <ToolbarSpacer/>

                            <Button text="Sync All Now" press=".onSyncAllNow" class="slSyncAllBtn"/>
                            <Button text="X" type="Transparent" press=".onCloseSyncCenter" class="slSyncCloseBtn"/>
                        </HBox>

                        <ScrollContainer height="calc(100vh - 10rem)" vertical="true">

                            <VBox class="slSyncBody">

                                <VBox class="slSectionTitleTeal">
                                    <Text text="Ariba SCC - Supplier Key Figure Feeds" class="slSyncSectionTitle"/>
                                    <Text text="Last publish timestamp per BOM line . Direct from supplier MES via Ariba Network" class="slSyncSectionSub"/>
                                </VBox>

                                <Table items="{dashboard>/aribaFeeds}" class="slAribaTable">
                                    <columns>
                                        <Column><Text text="Supplier / BOM Line"/></Column>
                                        <Column hAlign="End"><Text text="Last Publish"/></Column>
                                        <Column hAlign="End"><Text text="Status"/></Column>
                                    </columns>

                                    <items>
                                        <ColumnListItem class="{dashboard>rowClass}">
                                            <cells>
                                                <VBox>
                                                    <Text text="{dashboard>supplier}" class="slSupplierName"/>
                                                    <Text text="{dashboard>bomLine}" class="slSupplierLine"/>
                                                </VBox>

                                                <Text text="{dashboard>lastPublish}" class="slLastPublish"/>

                                                <Text text="{dashboard>statusText}" class="{dashboard>statusClass}"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>

                                <VBox class="slSectionTitleBlue">
                                    <Text text="SAP S/4HANA - Data Sources" class="slSyncSectionTitle"/>
                                    <Text text="Inventory, demand signals, BOM and planned orders" class="slSyncSectionSub"/>
                                </VBox>

                                <VBox items="{dashboard>/sapSources}" class="slSourceList">
                                    <VBox class="{dashboard>cardClass}">

                                        <HBox alignItems="Start">
                                            <VBox>
                                                <HBox alignItems="Center">
                                                    <Text text="{dashboard>title}" class="slSourceTitle"/>
                                                    <Text text="{dashboard>tag}" class="slSourceTag"/>
                                                </HBox>

                                                <Text text="{dashboard>description}" class="slSourceDesc"/>

                                                <HBox class="slSourceMeta">
                                                    <Text text="Last sync:" class="slMetaLabel"/>
                                                    <Text text="{dashboard>lastSync}" class="slMetaGreen"/>
                                                    <Text text="Next:" class="slMetaLabel"/>
                                                    <Text text="{dashboard>nextSync}" class="slMetaBold"/>
                                                </HBox>

                                                <HBox class="slSourceMeta">
                                                    <Text text="Records:" class="slMetaLabel"/>
                                                    <Text text="{dashboard>records}" class="slMetaBold"/>
                                                </HBox>

                                                <Text text="{dashboard>warningText}" class="slWarningText"/>
                                            </VBox>

                                            <ToolbarSpacer/>

                                            <VBox alignItems="End">
                                                <Text text="{dashboard>statusText}" class="{dashboard>statusClass}"/>
                                                <Button text="Sync Now" press=".onSyncNow" class="slSyncNowBtn"/>
                                            </VBox>
                                        </HBox>

                                    </VBox>
                                </VBox>

                                <Text
                                    text="Scheduled syncs run daily at 02:00 UTC via SAP BTP Integration Suite. On-demand sync triggers an immediate delta extraction. Ariba SCC key figures are pushed by suppliers on their native cadence - manual sync requests a re-publish from the supplier portal."
                                    class="slInfoBox"/>

                            </VBox>

                        </ScrollContainer>

                    </VBox>

                </VBox>

        </VBox>

    </Page>

</mvc:View>