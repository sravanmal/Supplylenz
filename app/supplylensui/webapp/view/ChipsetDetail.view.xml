<mvc:View
    controllerName="sravan.bristlecone.supplylensui.controller.ChipsetDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page showHeader="false" class="cdPage">
        <VBox class="cdShell">

            <!-- PAGE HEADER -->
            <HBox
            width="100%"
            justifyContent="SpaceBetween"
            alignItems="Center">

            <HBox
                alignItems="Center"
                width="100%">

                <Button
                    text="Back"
                    press=".onBack"
                    class="cdBackBtn"/>

                <VBox class="cdTitleBlock">
                    <Text text="{detail>/chipset/name}" class="cdTitle"/>
                    <Text text="{detail>/chipset/subTitle}" class="cdSubTitle"/>
                </VBox>
            </HBox>

            <ObjectStatus
                text="{detail>/chipset/riskBadge}"
                class="cdRiskBadge"/>
        </HBox>

            <!-- AVAILABILITY SECTION -->
            <VBox class="cdAvailabilityCard">


                <!-- DARK AVAILABILITY SECTION -->
                <VBox class="cdAvailabilityDarkSection">
                    <Text text="{detail>/availability/title}" class="cdDarkTitle"/>

                    <HBox class="cdDarkKpiRow" wrap="Wrap">
                        <VBox class="cdDarkKpi">
                            <Text text="Customer" class="cdDarkKpiLabel"/>
                            <Text text="{detail>/availability/customer}" class="cdDarkKpiValue"/>
                        </VBox>

                        <VBox class="cdDarkKpi">
                            <Text text="Committed Demand" class="cdDarkKpiLabel"/>
                            <Text text="{detail>/availability/committedDemand}" class="cdDarkKpiValue"/>
                        </VBox>

                        <VBox class="cdDarkKpi">
                            <Text text="Producible" class="cdDarkKpiLabel"/>
                            <Text text="{detail>/availability/producible}" class="cdDarkKpiValueGreen"/>
                        </VBox>

                        <VBox class="cdDarkKpi">
                            <Text text="Supply Gap" class="cdDarkKpiLabel"/>
                            <Text text="{detail>/availability/supplyGap}" class="cdDarkKpiValueRed"/>
                        </VBox>

                        <VBox class="cdDarkKpi">
                            <Text text="Revenue at Risk" class="cdDarkKpiLabel"/>
                            <Text text="{detail>/availability/revenueAtRisk}" class="cdDarkKpiValueRed"/>
                        </VBox>

                        <VBox class="cdDarkKpi">
                            <Text text="Safety Stock Target" class="cdDarkKpiLabel"/>
                            <Text text="{detail>/availability/safetyStockTarget}" class="cdDarkKpiValueBlue"/>
                        </VBox>

                        <VBox class="cdDarkKpi">
                            <Text text="Coverage" class="cdDarkKpiLabel"/>
                            <Text text="{detail>/availability/coverage}" class="cdDarkKpiValueOrange"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- STOCK LEGEND -->
                <HBox class="cdLegend" alignItems="Center" wrap="Wrap">
                    <Text text="Stock per plant:" class="cdLegendTitle"/>

                    <Text text="" class="cdLegendBoxGreen"/>
                    <Text text="Unrestricted - available to ship immediately" class="cdLegendText"/>

                    <Text text="" class="cdLegendBoxOrange"/>
                    <Text text="Quality Inspection - hold pending QC release" class="cdLegendText"/>

                    <Text text="" class="cdLegendBoxRed"/>
                    <Text text="Blocked - damage, return, or compliance hold" class="cdLegendText"/>
                </HBox>

                <!-- PORTFOLIO TOTAL -->
                <HBox
                    class="cdTotalRow"
                    justifyContent="SpaceBetween"
                    alignItems="Center">

                    <Text text="PORTFOLIO TOTAL" class="cdTotalTitle"/>

                    <HBox class="cdPortfolioKpis">
                        <VBox class="cdTotalBox">
                            <Text text="UNRESTRICTED" class="cdTotalLabel"/>
                            <Text text="{detail>/portfolio/unrestricted}" class="cdGreenValue"/>
                        </VBox>

                        <VBox class="cdTotalBox">
                            <Text text="QUALITY" class="cdTotalLabel"/>
                            <Text text="{detail>/portfolio/quality}" class="cdOrangeValue"/>
                        </VBox>

                        <VBox class="cdTotalBox">
                            <Text text="BLOCKED" class="cdTotalLabel"/>
                            <Text text="{detail>/portfolio/blocked}" class="cdRedValue"/>
                        </VBox>

                        <VBox class="cdTotalBox">
                            <Text text="TOTAL STOCK" class="cdTotalLabel"/>
                            <Text text="{detail>/portfolio/totalStock}" class="cdDarkValue"/>
                        </VBox>

                        <VBox class="cdTotalBox">
                            <Text text="WoS (unrestr.)" class="cdTotalLabel"/>
                            <Text text="{detail>/portfolio/wos}" class="cdOrangeValue"/>
                        </VBox>
                    </HBox>

                </HBox>

                <!-- PLANT TABLE -->
                <Table
                    class="cdPlantTable"
                    items="{detail>/plants}"
                    mode="None"
                    fixedLayout="true">

                    <columns>
                        <Column width="22%">
                            <Text text="Plant / Location"/>
                        </Column>

                        <Column width="12%">
                            <Text text="Type"/>
                        </Column>

                        <Column width="10%" hAlign="Center">
                            <Text text="Unrestricted"/>
                        </Column>

                        <Column width="10%" hAlign="Center">
                            <Text text="Quality Insp."/>
                        </Column>

                        <Column width="10%" hAlign="Center">
                            <Text text="Blocked"/>
                        </Column>

                        <Column width="10%" hAlign="Center">
                            <Text text="Total"/>
                        </Column>

                        <Column width="10%" hAlign="Center">
                            <Text text="WoS"/>
                        </Column>

                        <Column width="8%" hAlign="Center">
                            <Text text="Status"/>
                        </Column>

                        <Column width="18%">
                            <Text text="Note"/>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem
                            type="Active"
                            press=".onPlantPress"
                            class="cdPlantRow">

                            <cells>
                                <VBox>
                                    <Text text="{detail>name}" class="cdPlantName"/>
                                    <Text text="{detail>location}" class="cdPlantLocation"/>
                                </VBox>

                                <Text text="{detail>type}" class="cdTypeBadge"/>

                                <Text text="{detail>unrestricted}" class="cdGreenValueSmall"/>
                                <Text text="{detail>quality}" class="cdOrangeValueSmall"/>
                                <Text text="{detail>blocked}" class="cdRedValueSmall"/>
                                <Text text="{detail>total}" class="cdDarkValueSmall"/>

                                <HBox alignItems="Center" justifyContent="Center">
                                    <VBox class="cdWosTrack">
                                        <VBox
                                            class="cdWosFill"
                                            width="{= ${detail>wosPercent} ? ${detail>wosPercent} + '%' : '0%' }"/>
                                    </VBox>

                                    <Text text="{detail>wos}" class="cdWosText"/>
                                </HBox>

                                <Text
                                    text="{detail>status}"
                                    class="{= ${detail>status} === 'Critical' ? 'cdCriticalBadge' : (${detail>status} === 'Watch' ? 'cdWatchBadge' : 'cdHealthyBadge') }"/>

                                <Text text="{detail>note}" class="cdNoteText"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>

            <!-- SIDE PANEL -->
            <HBox
                visible="{detail>/showSidePanel}"
                class="cdOverlay"
                justifyContent="End">

                <VBox class="cdSidePanel">

                    <!-- Header -->
                    <HBox class="cdSideHeader">

                    <VBox class="cdSideHeaderText">
                        <Text
                            text="{detail>/selectedPlant/name}"
                            class="cdSideTitle"/>

                        <Text
                            text="{detail>/selectedPlant/location}"
                            class="cdSideLocation"/>
                    </VBox>

                    <Button
                        icon="sap-icon://decline"
                        type="Transparent"
                        press=".onCloseSidePanel"
                        class="cdSideCloseBtn"/>

                </HBox>

                    <!-- Risk Summary Box -->
                    <HBox
                        class="{= ${detail>/selectedPlant/status} === 'Critical' ? 'cdRiskSummaryBox cdCriticalBox' : (${detail>/selectedPlant/status} === 'Watch' ? 'cdRiskSummaryBox cdWatchBox' : 'cdHealthyBox cdRiskSummaryBox') }"
                        alignItems="Center">

                        <VBox
                            class="{= ${detail>/selectedPlant/status} === 'Critical' ? 'cdSideScoreCircle cdSideScoreCritical' : (${detail>/selectedPlant/status} === 'Watch' ? 'cdSideScoreCircle cdSideScoreWatch' : 'cdSideScoreCircle cdSideScoreHealthy') }">
                            <Text text="{detail>/selectedPlant/score}" class="cdSideScore"/>
                        </VBox>

                        <VBox>
                            <Text text="{detail>/selectedPlant/coverage}" class="cdSideUnits"/>
                            <Text text="{detail>/selectedPlant/status}" class="cdSideStatus"/>
                        </VBox>
                    </HBox>

                    <!-- WoS Progress -->
                    <Text text="Weeks of Supply vs 4-wk target" class="cdSideLabel"/>

                    <VBox class="cdSideProgressTrack">
                        <VBox
                            class="{= ${detail>/selectedPlant/status} === 'Critical' ? 'cdSideProgressFillCritical' : (${detail>/selectedPlant/status} === 'Watch' ? 'cdSideProgressFillWatch' : 'cdSideProgressFillHealthy') }"
                            width="{= ${detail>/selectedPlant/wosPercent} ? ${detail>/selectedPlant/wosPercent} + '%' : '0%' }"/>
                    </VBox>

                    <HBox class="cdSideWosRow">
                        <Text text="{detail>/selectedPlant/wos}" class="cdSideWos"/>
                        <ToolbarSpacer/>
                        <Text text="4 wks target" class="cdSideTarget"/>
                    </HBox>

                    <!-- Actions -->
                    <Text text="Recommended Actions" class="cdSideLabel"/>

                    <VBox items="{detail>/selectedPlant/recommendedActions}">
                        <HBox class="cdActionBox" alignItems="Center">
                            <Text text="{detail>}" class="cdActionText"/>
                        </HBox>
                    </VBox>

                    <!-- Info Box -->
                    <Text
                        text="OEM chipset stock. Updated daily via WMS. Safety stock = 4-week rolling demand average."
                        class="cdInfoBox"/>

                </VBox>
            </HBox>

            
        </VBox>
    </Page>
</mvc:View>